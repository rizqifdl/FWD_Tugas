<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Biodata Lengkap</title>
    <style>
        body{
            font-family: 'Segoe UI', Tahoma, Verdana, sans-serif;
            background-color: #f0f2f5;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
        }
        .biodata-card {
            background-color: #ffffff;
            width: 400px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            overflow: hidden;
            text-align: center;
            padding-bottom: 20px;
        }
        .header {
            background: linear-gradient(red,blue);
            color: white;
            padding: 20px;
            font-size: 24px;
            font-weight: bold;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        .photo-container {
            margin: -15px auto 15px;
            width: 100px;
            height: 100px;
            border-radius: 50%;
            border: 5px solid white;
            background-color: #ddd;
            overflow: hidden;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 5px 15px rgba(0,0,0,0.2);
        }
        .photo-container img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .name {
            font-size: 22px;
            font-weight: 700;
            color: #333;
            margin-bottom: 1px;
        }

        .job-title {
            color: #666;
            font-size: 14px;
            margin-bottom: 10px;
            font-style: italic;
        }

        .details {
            text-align: left;
            padding: 0 30px;
        }

        .detail-row {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #eee;
        }

        .detail-row:last-child {
            border-bottom: none;
        }

        .label {
            font-weight: 600;
            color: #555;
            font-size: 14px;
        }

        .value {
            color: #333;
            font-size: 14px;
            text-align: right;
            max-width: 60%;
        }

        .footer {
            margin-top: 20px;
            font-size: 12px;
            color: #888;
        }
    </style>
</head>
<body>

    <div class="biodata-card">
        <div class="header">Biodata Lengkap</div>
        
        <div class="photo-container">
            <img src="data:image/png;base64," alt="Foto dari Internet">
        </div>

        <div class="name">Rizqi Fadilah</div>
        <div class="job-title">Mahasiswa</div>

        <div class="details">
            <div class="detail-row">
                <span class="label">Tempat, Tanggal Lahir</span>
                <span class="value">Bekasi, 23 Maret 2005</span>
            </div>
            <div class="detail-row">
                <span class="label">Jenis Kelamin</span>
                <span class="value">Laki-Laki</span>
            </div>
            <div class="detail-row">
                <span class="label">Agama</span>
                <span class="value">Islam</span>
            </div>
            <div class="detail-row">
                <span class="label">Alamat</span>
                <span class="value">Jl. Mawar No. 79, Jatimekar, Jatiasih, Kota Bekasi</span>
            </div>
            <div class="detail-row">
                <span class="label">Status Perkawinan</span>
                <span class="value">Belum Menikah</span>
            </div>
            <div class="detail-row">
                <span class="label">Kewarganegaraan</span>
                <span class="value">Indonesia (WNI)</span>
            </div>
            <div class="detail-row">
                <span class="label">No. Telepon</span>
                <span class="value">0896-7111-6099</span>
            </div>
            <div class="detail-row">
                <span class="label">Email</span>
                <span class="value">rizqifdl216@gmailcom</span>
            </div>
        </div>

        <div class="footer">
            &copy; 2025 Biodata Pribadi
        </div>
    </div>

</body>
